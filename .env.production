# ── Railway environment variables — set these in the Railway dashboard ────────
# This file documents what variables are required. Do NOT put real secrets here.

# Neo4j Aura (required in production)
NEO4J_URI=neo4j+s://977a9e24.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<set in Railway dashboard>

# CORS — add your Vercel frontend URL once deployed
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3001

# legislation.gov.uk — public API, no credentials needed
LEGISLATION_BASE_URL=https://www.legislation.gov.uk

# LLM — Infermatic AI for citation explanations (optional)
INFERMATIC_API_KEY=<set in Railway dashboard>
INFERMATIC_BASE_URL=https://api.totalgpt.ai
INFERMATIC_MODEL=Qwen-Qwen3.6-35B-A3B

# Anthropic fallback (optional)
ANTHROPIC_API_KEY=

# OpenRouter — Nemotron pipeline (optional, activates Steps 3-5 when set)
# Enable data sharing at https://openrouter.ai/settings/privacy first
OPENROUTER_API_KEY=<set in Railway dashboard>
OPENROUTER_NANO_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_SUPER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_ULTRA_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
