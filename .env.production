# ── Variables de entorno para producción (Railway / Render) ──────────────────
# Copiar estos valores al dashboard de Railway como variables de entorno.
# NUNCA subir este archivo con valores reales a git.

# Neo4j Aura (reemplazar con credenciales reales)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# CORS — añadir la URL de Vercel cuando esté desplegado
# Formato: URL1,URL2 (sin espacios)
CORS_ORIGINS=https://citationguard.vercel.app,http://localhost:3001

# LLM
ANTHROPIC_API_KEY=
# INFERMATIC (si se usa en lugar de Anthropic)
INFERMATIC_API_KEY=
INFERMATIC_BASE_URL=https://api.infermatic.ai/v1
INFERMATIC_MODEL=qwen3-235b-a22b

# legislation.gov.uk — no requiere credenciales
LEGISLATION_BASE_URL=https://www.legislation.gov.uk
