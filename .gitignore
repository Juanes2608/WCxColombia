# Local env — NEVER commit secrets (API keys live here, only read server-side)
.env
.env.*
!.env.example

# Wrangler / Cloudflare
.wrangler/
.dev.vars

# Package managers: no lockfile is committed so Cloudflare runs a tolerant
# `npm install` on its own Linux/Node toolchain. Committing a lockfile generated
# on a different OS/Node version produced extraneous entries that broke `npm ci`.
bun.lock
package-lock.json

