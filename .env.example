# Copy to .env.local (gitignored) and fill in. NEVER commit real secrets.

# Anthropic key for the pricing chatbot proxy — read ONLY server-side by
# scripts/chat-proxy.mjs. It is NOT VITE_-prefixed, so Vite never ships it to the browser.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Where the frontend sends CHAT requests. For local testing this is the proxy.
# (Scan/verify still uses VITE_API_URL from the tracked .env — they can differ.)
VITE_CHAT_API_URL=http://localhost:8787

# Optional: override the model (default: claude-haiku-4-5)
# CHAT_MODEL=claude-haiku-4-5
# Optional: override the proxy port (default: 8787)
# CHAT_PROXY_PORT=8787
