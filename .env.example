# Copy this file to ".env" and fill in your Neo4j details.
#
# LOCAL (Neo4j Desktop 2 — recommended for this layer, fully offline/private):
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-with-your-local-password
NEO4J_DATABASE=neo4j
#
# CLOUD alternative (Neo4j Aura Free): use the neo4j+s:// URI it gives you.
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# AURA_INSTANCEID=xxxxxxxx

# Embedding provider for the retrieval layer: local (offline) | nemo (NVIDIA)
EMBED_PROVIDER=local
