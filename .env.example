# Neo4j Aura Free — única base de datos (corpus + tratamiento + proposiciones)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# App
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
PORT=8000

# legislation.gov.uk — sin credenciales (API pública)
LEGISLATION_BASE_URL=https://www.legislation.gov.uk

# LLM (para explanation engine opcional — el core NO lo usa)
ANTHROPIC_API_KEY=

# ── Nemotron Agent (OpenRouter) ───────────────────────────────────────────────
# Primary LLM for the agentic citation verification pipeline.
# Get a key at https://openrouter.ai → Settings → API Keys
# Required for agentic path; without it the deterministic fallback is used.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_SUPER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── Infermatic fallback (Qwen 3.6-35B) ───────────────────────────────────────
# Activated automatically when Nemotron returns 429 / 5xx.
# Get a key at https://totalgpt.ai
INFERMATIC_API_KEY=sk-...
INFERMATIC_MODEL=Qwen-Qwen3.6-35B-A3B

# Jus Mundi (si los organizadores proveen acceso — integración opcional)
JUS_MUNDI_API_KEY=
