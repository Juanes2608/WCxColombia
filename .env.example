# ── CitationGuard Backend — Environment Variables ──────────────────────────
# Copy to .env and fill real values. NEVER commit .env.

# Neo4j Aura (if empty, falls back to local CSV corpus — demo works either way)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# CORS — add Vercel/frontend URL in production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# legislation.gov.uk — public API, no credentials required
LEGISLATION_BASE_URL=https://www.legislation.gov.uk

# Infermatic AI — LLM for citation explanations (optional)
INFERMATIC_API_KEY=
INFERMATIC_BASE_URL=https://api.totalgpt.ai
INFERMATIC_MODEL=Qwen-Qwen3.6-35B-A3B

# Anthropic — fallback if Infermatic not configured
ANTHROPIC_API_KEY=

# OpenRouter — Nemotron multi-agent pipeline (Steps 3-5)
# Enable data sharing at https://openrouter.ai/settings/privacy for free models
OPENROUTER_API_KEY=
OPENROUTER_NANO_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_SUPER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_ULTRA_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
